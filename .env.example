# ============================================================
#  BE-AGENT — Variables d'environnement
#  Copier ce fichier en .env et remplir chaque valeur
# ============================================================

# --- META / WHATSAPP BUSINESS API ---
# Token d'accès permanent généré dans Meta Developers
WHATSAPP_TOKEN=

# Token de vérification que vous choisissez librement (webhook verify token)
VERIFY_TOKEN=mon_token_secret_123

# ID du numéro de téléphone WhatsApp Business (Phone Number ID)
PHONE_NUMBER_ID=

# Version de l'API Graph (ex: v19.0)
META_API_VERSION=v19.0

# --- ANTHROPIC / CLAUDE ---
# Clé API disponible sur https://console.anthropic.com
ANTHROPIC_API_KEY=

# Modèle Claude à utiliser
CLAUDE_MODEL=claude-opus-4-5

# Nombre maximum de tokens dans la réponse Claude
CLAUDE_MAX_TOKENS=1024

# --- GOOGLE SHEETS ---
# ID du Google Sheet (dans l'URL : /spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=

# Nom de l'onglet principal où enregistrer les conversations
GOOGLE_SHEET_TAB=Conversations

# Chemin vers le fichier JSON du compte de service Google
# (ou laisser vide et renseigner GOOGLE_SERVICE_ACCOUNT_JSON en ligne)
GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/google-service-account.json

# Optionnel : JSON brut du compte de service (utile pour Railway / env vars)
# GOOGLE_SERVICE_ACCOUNT_JSON=

# --- SERVEUR ---
PORT=3000

# Environnement : development | production
NODE_ENV=development

# --- CRON ---
# Heure d'envoi du rapport quotidien (format cron, ex: tous les jours à 8h)
CRON_DAILY_REPORT=0 8 * * *

# Numéro WhatsApp du responsable qui reçoit les rapports (format international sans +)
ADMIN_WHATSAPP_NUMBER=
